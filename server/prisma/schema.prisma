// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GUEST
  ADMIN
}

enum HouseType {
  Apartment
  Home
  House
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String
  phone    String?

  role     Role      @default(GUEST)
  bookings Booking[]

  favoriteHouses House[] @relation("UserFavoriteHouses")
  favoriteCities City[]  @relation("UserFavoriteCities")
  ownedhouses    House[] @relation("HouseOwner")
}

model Country {
  id     Int    @id @default(autoincrement())
  name   String @unique
  cities City[]
}

model City {
  id   Int    @id @default(autoincrement())
  name String @unique

  countryId Int
  country   Country @relation(fields: [countryId], references: [id])

  Houses House[]

  favoritedBy User[] @relation("UserFavoriteCities")
}

model Image {
  id         Int       @id @default(autoincrement())
  url        String
  roomType   RoomType? @relation(fields: [roomTypeId], references: [id])
  roomTypeId Int?
  house      House?    @relation(fields: [houseId], references: [id])
  houseId    Int?
}

model House {
  id          Int       @id @default(autoincrement())
  name        String
  address     String
  animals     Boolean?
  type        HouseType
  cityId      Int
  description String?

  city        City       @relation(fields: [cityId], references: [id])
  roomTypes   RoomType[]
  favoritedBy User[]     @relation("UserFavoriteHouses")

  owner  User @relation("HouseOwner", fields: [userId], references: [id])
  userId Int

  images Image[]
}

model RoomType {
  id            Int     @id @default(autoincrement())
  name          String
  pricePerNight Float
  capacity      Int
  images        Image[]

  HouseId Int
  House   House  @relation(fields: [HouseId], references: [id])
  rooms   Room[]
}

model Room {
  id         Int    @id @default(autoincrement())
  roomNumber String

  roomTypeId Int
  roomType   RoomType  @relation(fields: [roomTypeId], references: [id])
  bookings   Booking[]
}

model Booking {
  id         Int      @id @default(autoincrement())
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float

  childrenCount Int

  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  roomId Int
  room   Room @relation(fields: [roomId], references: [id])
}
